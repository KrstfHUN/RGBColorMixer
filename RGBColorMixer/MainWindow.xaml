<Window x:Class="RGBColorMixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RGB Színkeverő" Height="520" Width="820"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Top" >

            <TextBlock Text="Vörös (R)" FontWeight="SemiBold" Foreground="#CC2222" Margin="0,0,0,2"/>
            <Slider x:Name="SliderR" Minimum="0" Maximum="255" Value="128"
                    ValueChanged="Slider_ValueChanged" Margin="0,0,0,4"/>

            <TextBlock Text="Zöld (G)" FontWeight="SemiBold" Foreground="#229922" Margin="0,0,0,2"/>
            <Slider x:Name="SliderG" Minimum="0" Maximum="255" Value="128"
                    ValueChanged="Slider_ValueChanged" Margin="0,0,0,4"/>

            <TextBlock Text="Kék (B)" FontWeight="SemiBold" Foreground="#2244CC" Margin="0,0,0,2"/>
            <Slider x:Name="SliderB" Minimum="0" Maximum="255" Value="128"
                    ValueChanged="Slider_ValueChanged" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <CheckBox x:Name="CbR" Content="Vörös" IsChecked="True"
                          Foreground="#CC2222" FontWeight="SemiBold" Margin="0,0,12,0"
                          Checked="Cb_Changed" Unchecked="Cb_Changed"/>
                <CheckBox x:Name="CbG" Content="Zöld" IsChecked="True"
                          Foreground="#229922" FontWeight="SemiBold" Margin="0,0,12,0"
                          Checked="Cb_Changed" Unchecked="Cb_Changed"/>
                <CheckBox x:Name="CbB" Content="Kék" IsChecked="True"
                          Foreground="#2244CC" FontWeight="SemiBold"
                          Checked="Cb_Changed" Unchecked="Cb_Changed"/>
            </StackPanel>

            <Border x:Name="ColorPreview" Height="60" CornerRadius="4"
                    BorderBrush="#AAAAAA" BorderThickness="1" Margin="0,0,0,12">
                <TextBlock x:Name="PreviewLabel" Text="" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontSize="11"/>
            </Border>

            <TextBlock x:Name="TbRgb" Text="RGB: (128, 128, 128)"
                       FontFamily="Consolas" Margin="0,0,0,4"/>
            <TextBlock x:Name="TbHex" Text="HEX: #808080"
                       FontFamily="Consolas" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Reset" Width="72" Margin="0,0,8,0" Click="BtnReset_Click"/>
                <Button Content="Véletlen" Width="72" Margin="0,0,8,0" Click="BtnRandom_Click"/>
                <Button Content="Törlés" Width="72" Click="BtnClear_Click"/>
            </StackPanel>

            <TextBlock Text="Ecsetvastagság:" FontWeight="SemiBold" Margin="0,0,0,2"/>
            <Slider x:Name="SliderBrush" Minimum="2" Maximum="60" Value="10"
                    ValueChanged="SliderBrush_Changed" Margin="0,0,0,4"/>
            <TextBlock x:Name="TbBrushSize" Text="Méret: 10 px" FontFamily="Consolas"/>

        </StackPanel>

        <Border Grid.Column="2" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4">
            <Canvas x:Name="DrawingCanvas" Background="White" ClipToBounds="True"
                    MouseDown="Canvas_MouseDown"
                    MouseMove="Canvas_MouseMove"
                    MouseUp="Canvas_MouseUp"
                    Cursor="Cross"/>
        </Border>
    </Grid>
</Window>
